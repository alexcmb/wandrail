# Copier en .env.local pour le dev (jamais commite).
#
# En dev, laisser vide : Vite fait un proxy de /api vers http://localhost:8000
# (voir vite.config.js). En production (Vercel/Netlify), mettre l'URL publique
# de l'API FastAPI deployee, par exemple :
#   VITE_API_BASE=https://wandrail-api.onrender.com
VITE_API_BASE=
